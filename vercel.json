{
  "version": 2,
  "builds": [
    {
      "src": "fondeino_web/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "fondeino_web/wsgi.py"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-src 'self' https://gamma.app https://*.gamma.site;"
        }
      ]
    }
  ]
}
