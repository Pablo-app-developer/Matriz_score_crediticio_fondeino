# Copiar este archivo como .env y configurar los valores
SECRET_KEY=django-insecure-reemplaza-con-clave-segura
DEBUG=False
ALLOWED_HOSTS=tu-dominio.vercel.app,localhost

# Base de datos (PostgreSQL recomendado para producción)
# Vercel Postgres / Neon / Supabase - copiar la URL de conexión
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Para desarrollo local con SQLite (por defecto si no se define DATABASE_URL):
# DATABASE_URL=sqlite:///db.sqlite3
